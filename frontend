<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ConstructAI — AI-Powered Construction Planning</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #060c18;
    --surface: #0a1628;
    --surface2: #0f1f38;
    --border: #1a3050;
    --accent: #00aaff;
    --accent2: #00e5cc;
    --accent3: #ff6b35;
    --steel: #8faabb;
    --white: #e8f0fe;
    --muted: #4a6480;
    --grid: rgba(0,170,255,0.04);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ====== NAV ====== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 3rem;
    background: rgba(6,12,24,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .nav-logo span { color: var(--white); }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--steel);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
  }

  .nav-links a:hover { color: var(--accent); }

  /* ====== SECTIONS ====== */
  section { position: relative; z-index: 1; }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  /* ====== HERO ====== */
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 4rem;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-eyebrow {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 3px;
    margin-bottom: 1.2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }

  .hero-title .highlight {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.2rem;
    color: var(--accent2);
    font-weight: 500;
    margin-bottom: 1.2rem;
    letter-spacing: 1px;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }

  .hero-desc {
    color: var(--steel);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,170,255,0.1);
    border: 1px solid rgba(0,170,255,0.3);
    border-radius: 20px;
    padding: 0.3rem 1rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.55s forwards;
  }

  .hero-badge::before { content: '●'; animation: pulse 2s infinite; }

  .btn-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s 0.7s forwards;
  }

  .btn-primary {
    padding: 0.85rem 2rem;
    background: linear-gradient(135deg, var(--accent), #0066cc);
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 1px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s, box-shadow 0.2s;
    text-transform: uppercase;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,170,255,0.4);
  }

  .btn-secondary {
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 1px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s, transform 0.2s;
    text-transform: uppercase;
  }

  .btn-secondary:hover {
    background: rgba(0,170,255,0.1);
    transform: translateY(-2px);
  }

  /* Hero Blueprint Visual */
  .hero-visual {
    position: relative;
    opacity: 0;
    animation: fadeIn 1s 0.8s forwards;
  }

  .blueprint-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .blueprint-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,170,255,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,170,255,0.06) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .blueprint-header {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
  }

  .bp-floor {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    margin-bottom: 1rem;
  }

  .bp-room {
    background: rgba(0,170,255,0.08);
    border: 1px solid rgba(0,170,255,0.25);
    border-radius: 2px;
    padding: 0.6rem 0.4rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.55rem;
    color: var(--accent);
    text-align: center;
  }

  .bp-room.wide { grid-column: span 2; }
  .bp-room.tall { grid-row: span 2; }
  .bp-room.highlight-room {
    background: rgba(0,229,204,0.12);
    border-color: rgba(0,229,204,0.4);
    color: var(--accent2);
  }

  .bp-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .bp-stat {
    background: rgba(0,170,255,0.05);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.6rem;
    text-align: center;
  }

  .bp-stat-val {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--accent2);
  }

  .bp-stat-lbl {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    margin-top: 2px;
  }

  /* ====== SECTION HEADERS ====== */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .section-title .hl { color: var(--accent); }

  .section-sub {
    color: var(--steel);
    font-size: 0.95rem;
    margin-top: 0.8rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ====== ABOUT SECTION ====== */
  #about { padding: 8rem 0; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-features {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .feature-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 0.2s;
  }

  .feature-row:hover { border-color: var(--accent); }

  .feature-icon {
    font-size: 1.5rem;
    min-width: 2.5rem;
    text-align: center;
  }

  .feature-text h4 {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.5px;
    margin-bottom: 0.3rem;
    color: var(--white);
  }

  .feature-text p {
    color: var(--steel);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .about-info h3 {
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .about-info p {
    color: var(--steel);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(0,170,255,0.1);
    border: 1px solid rgba(0,170,255,0.3);
    color: var(--accent);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    margin: 0.3rem;
    display: inline-block;
  }

  /* ====== SCENARIOS ====== */
  #scenarios { padding: 8rem 0; background: linear-gradient(to bottom, transparent, rgba(10,22,40,0.5), transparent); }

  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .scenario-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .scenario-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 12px 40px rgba(0,170,255,0.15);
  }

  .scenario-header {
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .scenario-num {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.4rem;
    color: var(--accent);
    font-weight: bold;
    min-width: 2.5rem;
  }

  .scenario-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.5px;
  }

  .scenario-body { padding: 1.5rem; }

  .scenario-body.hidden { display: none; }

  .scenario-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent2);
    letter-spacing: 2px;
    margin-bottom: 0.8rem;
    display: block;
  }

  .data-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.85rem;
  }

  .data-row:last-child { border-bottom: none; }
  .data-row .key { color: var(--steel); }
  .data-row .val { color: var(--white); font-weight: 500; font-family: 'Rajdhani', sans-serif; font-size: 1rem; }
  .data-row .val.accent { color: var(--accent2); }

  .expand-hint {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--muted);
    text-align: center;
    padding: 0.8rem;
    border-top: 1px solid var(--border);
    transition: color 0.2s;
  }

  .scenario-card:hover .expand-hint { color: var(--accent); }

  /* ====== FEATURES ====== */
  #features { padding: 8rem 0; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .feat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }

  .feat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .feat-card:hover { transform: translateY(-4px); border-color: rgba(0,170,255,0.3); }
  .feat-card:hover::before { opacity: 1; }

  .feat-icon { font-size: 2rem; margin-bottom: 1rem; }

  .feat-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .feat-desc { color: var(--steel); font-size: 0.85rem; line-height: 1.6; }

  /* ====== ARCHITECTURE ====== */
  #architecture { padding: 8rem 0; }

  .arch-diagram {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }

  .arch-diagram::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,170,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,170,255,0.04) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .arch-layers {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .arch-layer {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .arch-node {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.8rem 1.5rem;
    text-align: center;
    transition: border-color 0.2s, box-shadow 0.2s;
    min-width: 140px;
  }

  .arch-node:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(0,170,255,0.2);
  }

  .arch-node-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }

  .arch-node-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
    color: var(--white);
  }

  .arch-node-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    margin-top: 2px;
  }

  .arch-node.primary {
    border-color: rgba(0,170,255,0.4);
    background: rgba(0,170,255,0.08);
  }

  .arch-node.secondary {
    border-color: rgba(0,229,204,0.3);
    background: rgba(0,229,204,0.06);
  }

  .arch-connector {
    width: 2px;
    height: 30px;
    background: linear-gradient(to bottom, var(--accent), var(--accent2));
    margin: 0 auto;
    position: relative;
    opacity: 0.5;
  }

  .arch-connector::after {
    content: '▼';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    color: var(--accent2);
  }

  /* ====== TECH STACK ====== */
  #stack { padding: 8rem 0; }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }

  .stack-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: transform 0.2s, border-color 0.2s;
  }

  .stack-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .stack-icon { font-size: 2.2rem; margin-bottom: 0.8rem; }

  .stack-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.5px;
  }

  .stack-version {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    margin-top: 4px;
  }

  /* ====== TIMELINE ====== */
  #timeline { padding: 8rem 0; }

  .timeline-track {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .timeline-track::before {
    content: '';
    position: absolute;
    left: 2.2rem;
    top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), var(--accent2), transparent);
  }

  .tl-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
    position: relative;
    opacity: 0;
    transform: translateX(-20px);
    animation: slideIn 0.6s forwards;
  }

  .tl-item:nth-child(1) { animation-delay: 0.1s; }
  .tl-item:nth-child(2) { animation-delay: 0.2s; }
  .tl-item:nth-child(3) { animation-delay: 0.3s; }
  .tl-item:nth-child(4) { animation-delay: 0.4s; }
  .tl-item:nth-child(5) { animation-delay: 0.5s; }

  .tl-dot {
    min-width: 2.5rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--surface2);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--accent);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    margin-top: 0.2rem;
    box-shadow: 0 0 12px rgba(0,170,255,0.3);
  }

  .tl-content {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.2rem 1.5rem;
    flex: 1;
    transition: border-color 0.2s;
  }

  .tl-content:hover { border-color: var(--accent); }

  .tl-week {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: 0.4rem;
  }

  .tl-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .tl-desc { color: var(--steel); font-size: 0.85rem; line-height: 1.5; }

  /* ====== REQUIREMENTS ====== */
  #requirements { padding: 8rem 0; }

  .req-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .req-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
  }

  .req-card-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .req-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--steel);
  }

  .req-item::before {
    content: '▹';
    color: var(--accent2);
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  /* ====== DEMO ====== */
  #demo { padding: 8rem 0; }

  .demo-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2rem;
    align-items: start;
  }

  .demo-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
  }

  .form-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    color: var(--accent);
    text-transform: uppercase;
  }

  .form-group { margin-bottom: 1.2rem; }

  .form-group label {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    color: var(--steel);
    letter-spacing: 1.5px;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    background: var(--bg);
