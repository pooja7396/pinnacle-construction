<script>
  // Toggle scenario cards
  function toggleScenario(card) {
    const body = card.querySelector('.scenario-body');
    const hint = card.querySelector('.expand-hint');
    const isHidden = body.classList.contains('hidden');
    body.classList.toggle('hidden');
    hint.textContent = isHidden ? '▲ CLICK TO COLLAPSE' : '▼ CLICK TO EXPAND ANALYSIS';
  }

  // Demo Analysis
  function runAnalysis() {
    const area = parseInt(document.getElementById('area').value);
    const floors = document.getElementById('floors').value;
    const timeline = parseInt(document.getElementById('timeline').value);
    const type = document.getElementById('type').value;

    if (!area || !floors || !timeline || !type) {
      alert('Please fill in all project parameters.');
      return;
    }

    const statusBadge = document.getElementById('status-badge');
    const resultsBody = document.getElementById('results-body');

    // Loading state
    statusBadge.textContent = 'PROCESSING';
    statusBadge.className = 'results-status loading';
    resultsBody.innerHTML = `
      <div style="text-align:center;padding:2rem;">
        <div style="font-family:'Share Tech Mono',monospace;font-size:0.75rem;color:var(--accent);margin-bottom:1rem;letter-spacing:2px;">IBM GRANITE 3.3 2B ANALYZING...</div>
        <div class="loading-bar"><div class="loading-fill" id="lbar"></div></div>
        <div style="font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--muted);margin-top:0.5rem;" id="lmsg">Initializing AI inference engine...</div>
      </div>
    `;

    // Animate loading bar
    const messages = [
      'Initializing AI inference engine...',
      'Parsing project parameters...',
      'Running cost estimation model...',
      'Calculating workforce requirements...',
      'Generating material quantities...',
      'Building weekly schedule...',
      'Compiling AI insights...'
    ];
    let progress = 0;
    let msgIndex = 0;
    const lbar = document.getElementById('lbar');
    const lmsg = document.getElementById('lmsg');

    const interval = setInterval(() => {
      progress += 14;
      if (lbar) lbar.style.width = Math.min(progress, 95) + '%';
      if (lmsg && messages[msgIndex]) { lmsg.textContent = messages[msgIndex]; msgIndex++; }
      if (progress >= 95) clearInterval(interval);
    }, 280);

    // Show results after delay
    setTimeout(() => {
      clearInterval(interval);
      const floorCount = { 'G': 1, 'G+1': 2, 'G+2': 3, 'G+3': 4, 'G+4': 5 }[floors] || 2;
      const totalArea = area * floorCount;

      // Estimation math
      const costPerSqYd = type === 'residential' ? 4800 : type === 'commercial' ? 6200 : 5400;
      const totalCost = totalArea * costPerSqYd;
      const labor = Math.round(totalCost * 0.35);
      const materials = Math.round(totalCost * 0.52);
      const overhead = Math.round(totalCost * 0.13);

      const workers = Math.round(totalArea / 30);
      const masons = Math.round(workers * 0.28);
      const helpers = Math.round(workers * 0.40);
      const steelWorkers = Math.round(workers * 0.15);
      const carpenters = Math.round(workers * 0.10);
      const others = workers - masons - helpers - steelWorkers - carpenters;

      const cement = Math.round(totalArea * 1.8);
      const steel = Math.round(totalArea * 0.022);
      const sand = Math.round(totalArea * 4.2);
      const bricks = Math.round(totalArea * 22);
      const weeks = Math.ceil(timeline / 7);

      statusBadge.textContent = 'COMPLETE';
      statusBadge.className = 'results-status done';

      resultsBody.innerHTML = `
        <div class="result-section">
          <div class="result-section-title">👷 Workforce Requirements</div>
          <div class="result-rows">
            <div class="result-row"><span class="rk">Masons</span><span class="rv">${masons} workers</span></div>
            <div class="result-row"><span class="rk">Helpers / Laborers</span><span class="rv">${helpers} workers</span></div>
            <div class="result-row"><span class="rk">Steel Workers</span><span class="rv">${steelWorkers} workers</span></div>
            <div class="result-row"><span class="rk">Carpenters</span><span class="rv">${carpenters} workers</span></div>
            <div class="result-row"><span class="rk">MEP & Others</span><span class="rv">${others} workers</span></div>
            <div class="result-row" style="background:rgba(0,229,204,0.06);"><span class="rk"><strong>Total Workforce</strong></span><span class="rv highlight"><strong>${workers} workers</strong></span></div>
          </div>
        </div>

        <div class="result-section">
          <div class="result-section-title">💰 Cost Estimation</div>
          <div class="result-rows">
            <div class="result-row"><span class="rk">Labor Cost</span><span class="rv">₹${labor.toLocaleString('en-IN')}</span></div>
            <div class="result-row"><span class="rk">Material Cost</span><span class="rv">₹${materials.toLocaleString('en-IN')}</span></div>
            <div class="result-row"><span class="rk">Overhead & Misc</span><span class="rv">₹${overhead.toLocaleString('en-IN')}</span></div>
            <div class="result-row" style="background:rgba(0,229,204,0.06);"><span class="rk"><strong>Total Estimate</strong></span><span class="rv highlight"><strong>₹${totalCost.toLocaleString('en-IN')}</strong></span></div>
          </div>
        </div>

        <div class="result-section">
          <div class="result-section-title">🧱 Material Quantities</div>
          <div class="result-rows">
            <div class="result-row"><span class="rk">Cement</span><span class="rv">${cement.toLocaleString()} bags</span></div>
            <div class="result-row"><span class="rk">Steel</span><span class="rv">${steel} MT</span></div>
            <div class="result-row"><span class="rk">Sand</span><span class="rv">${sand.toLocaleString()} cu ft</span></div>
            <div class="result-row"><span class="rk">Bricks</span><span class="rv">${bricks.toLocaleString()} units</span></div>
          </div>
        </div>

        <div class="result-section">
          <div class="result-section-title">📅 Timeline Summary</div>
          <div class="result-rows">
            <div class="result-row"><span class="rk">Project Duration</span><span class="rv">${timeline} days (${weeks} weeks)</span></div>
            <div class="result-row"><span class="rk">Foundation Phase</span><span class="rv">Weeks 1–${Math.round(weeks*0.15)}</span></div>
            <div class="result-row"><span class="rk">Structure Phase</span><span class="rv">Weeks ${Math.round(weeks*0.15)+1}–${Math.round(weeks*0.65)}</span></div>
            <div class="result-row"><span class="rk">Finishing Phase</span><span class="rv">Weeks ${Math.round(weeks*0.65)+1}–${weeks}</span></div>
            <div class="result-row" style="background:rgba(0,229,204,0.06);"><span class="rk"><strong>Total Built-Up Area</strong></span><span class="rv highlight"><strong>${totalArea.toLocaleString()} sq yd</strong></span></div>
          </div>
        </div>
      `;
    }, 2100);
  }

  // Intersection Observer for scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'none';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.feat-card, .stack-card, .req-card, .scenario-card').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });
</script>
