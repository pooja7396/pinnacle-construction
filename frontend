<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Construction Planner | IBM Granite 3.3</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    <style>
        :root {
            --primary-blue: #002D72;
            --blueprint-blue: #0A192F;
            --accent-steel: #8892B0;
            --text-light: #E6F1FF;
            --glass: rgba(255, 255, 255, 0.05);
            --border-glass: rgba(255, 255, 255, 0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background-color: var(--blueprint-blue);
            color: var(--text-light);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
            background-image: 
                linear-gradient(rgba(10, 25, 47, 0.9), rgba(10, 25, 47, 0.9)),
                repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(0, 45, 114, 0.1) 50px),
                repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(0, 45, 114, 0.1) 50px);
        }

        /* --- Global Styles --- */
        section { padding: 80px 10%; }
        h2 { font-size: 2.5rem; margin-bottom: 2rem; border-left: 5px solid var(--primary-blue); padding-left: 1rem; }
        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 2rem;
            transition: transform 0.3s ease;
        }
        .glass-card:hover { transform: translateY(-5px); }

        /* --- 1. Hero Section --- */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: radial-gradient(circle at center, rgba(0, 45, 114, 0.2) 0%, transparent 70%);
        }
        .hero h1 { font-size: 4rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 1rem; }
        .hero p { max-width: 700px; font-size: 1.1rem; color: var(--accent-steel); margin-bottom: 2rem; }
        .btn-group { display: flex; gap: 20px; }
        .btn {
            padding: 15px 35px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }
        .btn-primary { background: #007BFF; color: white; }
        .btn-outline { border: 2px solid #007BFF; color: #007BFF; }

        /* --- 4. Core Features --- */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        .feature-item { text-align: center; padding: 3rem 1.5rem; }
        .feature-item i { font-size: 2.5rem; color: #007BFF; margin-bottom: 1.5rem; }

        /* --- 9. Demo Section --- */
        .demo-container { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
        .demo-form input {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-glass);
            color: white;
            border-radius: 4px;
        }
        .results-box { min-height: 300px; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; }
        .results-box h4 { color: #00FFCC; margin-bottom: 1rem; }

        /* --- 7. Workflow Timeline --- */
        .timeline { border-left: 2px solid #007BFF; margin-left: 20px; padding-left: 30px; position: relative; }
        .timeline-item { margin-bottom: 40px; position: relative; }
        .timeline-item::before {
            content: '';
            width: 15px;
            height: 15px;
            background: #007BFF;
            border-radius: 50%;
            position: absolute;
            left: -39px;
            top: 5px;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .demo-container { grid-template-columns: 1fr; }
            section { padding: 60px 5%; }
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <section class="hero">
        <h1>AI-Powered Construction Planning</h1>
        <p>Intelligent Estimation, Resource Planning & Scheduling powered by <strong>IBM Granite 3.3 2B</strong>. Fast, secure, and running locally via Ollama.</p>
        <div class="btn-group">
            <a href="#demo" class="btn btn-primary">Start Planning</a>
            <a href="#" class="btn btn-outline">View Architecture</a>
        </div>
    </section>

    <!-- Core Features -->
    <section id="features">
        <h2>Core Features</h2>
        <div class="features-grid">
            <div class="glass-card feature-item">
                <i class="fas fa-calculator"></i>
                <h3>Cost Estimation</h3>
                <p>Real-time AI analysis of material and labor market rates.</p>
            </div>
            <div class="glass-card feature-item">
                <i class="fas fa-users"></i>
                <h3>Workforce Planning</h3>
                <p>Precise breakdown of masons, helpers, and steel workers.</p>
            </div>
            <div class="glass-card feature-item">
                <i class="fas fa-drafting-compass"></i>
                <h3>Blueprint Gen</h3>
                <p>Automated architectural layouts based on area parameters.</p>
            </div>
            <div class="glass-card feature-item">
                <i class="fas fa-shield-alt"></i>
                <h3>Local Inference</h3>
                <p>No Cloud APIs. Your data stays on your local hardware.</p>
            </div>
        </div>
    </section>

    <!-- Demo Section -->
    <section id="demo">
        <h2>Interactive AI Demo</h2>
        <div class="demo-container">
            <div class="glass-card demo-form">
                <h3>Project Parameters</h3>
                <label>Built-up Area (Sq Ft)</label>
                <input type="number" id="area" placeholder="e.g., 2500">
                <label>Number of Floors</label>
                <input type="number" id="floors" placeholder="e.g., 2">
                <label>Desired Timeline (Days)</label>
                <input type="number" id="days" placeholder="e.g., 180">
                <button onclick="generatePlan()" class="btn btn-primary" style="width:100%; border:none; cursor:pointer;">Generate AI Report</button>
            </div>
            <div class="glass-card results-box" id="results">
                <div style="color: var(--accent-steel); text-align: center; margin-top: 100px;">
                    Enter parameters and click generate to see AI-backed construction insights.
                </div>
            </div>
        </div>
    </section>

    <!-- Workflow Section -->
    <section>
        <h2>Project Workflow</h2>
        <div class="timeline">
            <div class="timeline-item">
                <h4>Week 1: Setup</h4>
                <p>Environment configuration & Ollama Granite model pull.</p>
            </div>
            <div class="timeline-item">
                <h4>Weeks 2-3: Backend</h4>
                <p>Flask integration with Python calculation engines.</p>
            </div>
            <div class="timeline-item">
                <h4>Weeks 4-5: Frontend</h4>
                <p>Interactive UI & real-time result visualization.</p>
            </div>
        </div>
    </section>

    <!-- JS Logic -->
    <script>
        function generatePlan() {
            const area = document.getElementById('area').value;
            const floors = document.getElementById('floors').value;
            const res = document.getElementById('results');

            if(!area || !floors) {
                alert("Please fill in project details");
                return;
            }

            res.innerHTML = "<h4>Processing with IBM Granite 3.3...</h4><p>Analyzing parameters...</p>";

            setTimeout(() => {
                const totalCost = (area * 1850 * floors).toLocaleString();
                const workers = Math.ceil(area / 100);
                
                res.innerHTML = `
                    <h4><i class="fas fa-check-circle"></i> AI Analysis Complete</h4>
                    <div style="margin-top:15px;">
                        <p><strong>Estimated Budget:</strong> $${totalCost}</p>
                        <p><strong>Labor Force:</strong> ${workers} Workers/Day</p>
                        <p><strong>Materials:</strong> ${(area * 0.5).toFixed(0)} Tons Steel, ${(area * 4)} Bags Cement</p>
                        <p><strong>Schedule:</strong> Week-by-week roadmap generated.</p>
                        <hr style="margin:15px 0; opacity:0.1;">
                        <p style="font-size:0.8rem; color:#007BFF;">*Generated via local Ollama inference.</p>
                    </div>
                `;
            }, 1500);
        }
    </script>
</body>
</html>
