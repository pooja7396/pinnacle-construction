<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI-Construct | Intelligent Project Planning</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #0077ff;
            --deep-navy: #0a192f;
            --blueprint-grid: #112240;
            --steel-grey: #ccd6f6;
            --accent-cyan: #64ffda;
            --glass: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--deep-navy);
            color: var(--steel-grey);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
            background-image: 
                linear-gradient(var(--blueprint-grid) 1px, transparent 1px),
                linear-gradient(90deg, var(--blueprint-grid) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        /* --- Components --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 2rem;
            transition: transform 0.3s ease;
        }

        .btn {
            padding: 12px 28px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
            border: none;
        }

        .btn-primary {
            background: var(--primary-blue);
            color: white;
        }

        .btn-outline {
            border: 1px solid var(--primary-blue);
            color: var(--primary-blue);
            background: transparent;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 119, 255, 0.2);
        }

        /* --- Sections --- */

        /* 1. Hero Section */
        #hero {
            height: 100vh;
            display: flex;
            align-items: center;
            text-align: center;
            position: relative;
        }

        .hero-content h1 {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 800;
            color: white;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .hero-content p {
            font-size: 1.2rem;
            max-width: 700px;
            margin: 0 auto 30px;
        }

        .model-badge {
            display: inline-block;
            padding: 6px 15px;
            background: rgba(100, 255, 218, 0.1);
            color: var(--accent-cyan);
            border: 1px solid var(--accent-cyan);
            border-radius: 20px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        /* 2. Project Description */
        #description { padding: 100px 0; }
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            align-items: center;
        }

        /* 3. Real-World Scenarios */
        #scenarios { padding: 100px 0; }
        .scenario-card {
            margin-bottom: 15px;
            overflow: hidden;
        }
        .scenario-header {
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .scenario-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease;
        }
        .scenario-card.active .scenario-body {
            max-height: 1000px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--glass-border);
        }

        /* 4. Core Features */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 50px;
        }
        .feature-item {
            text-align: center;
            padding: 40px 20px;
        }
        .feature-item i {
            font-size: 2.5rem;
            color: var(--primary-blue);
            margin-bottom: 20px;
        }

        /* 5. System Architecture */
        .arch-box {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            padding: 40px;
            background: rgba(0,0,0,0.3);
            border-radius: 20px;
            position: relative;
        }
        .arch-node {
            padding: 20px;
            border: 2px solid var(--primary-blue);
            border-radius: 8px;
            background: var(--deep-navy);
            z-index: 2;
        }

        /* 7. Workflow Timeline */
        .timeline {
            position: relative;
            max-width: 800px;
            margin: 50px auto;
        }
        .timeline::after {
            content: '';
            position: absolute;
            width: 2px;
            background: var(--primary-blue);
            top: 0; bottom: 0; left: 50%;
        }
        .timeline-item {
            padding: 10px 40px;
            position: relative;
            width: 50%;
        }
        .timeline-item:nth-child(odd) { left: 0; text-align: right; }
        .timeline-item:nth-child(even) { left: 50%; }

        /* 9. Demo Section */
        #demo-form {
            display: grid;
            gap: 15px;
        }
        input, select {
            padding: 12px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--glass-border);
            color: white;
            border-radius: 4px;
        }
        .results-area {
            display: none;
            margin-top: 30px;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .timeline::after { left: 31px; }
            .timeline-item { width: 100%; padding-left: 70px; text-align: left !important; }
            .timeline-item:nth-child(even) { left: 0; }
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <section id="hero">
        <div class="container">
            <div class="hero-content">
                <div class="model-badge">Powered by IBM Granite 3.3 2B + Ollama</div>
                <h1>AI-Powered Construction<br><span style="color: var(--primary-blue);">Project Planning</span></h1>
                <p>Intelligent Estimation, Resource Planning & Scheduling. High-performance local AI inference for modern engineering.</p>
                <div style="margin-top: 30px;">
                    <a href="#demo" class="btn btn-primary">Start Planning</a>
                    <a href="#scenarios" class="btn btn-outline" style="margin-left: 15px;">View Architecture</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Project Description -->
    <section id="description">
        <div class="container">
            <div class="grid-2">
                <div>
                    <h2 style="font-size: 2.5rem; color: white; margin-bottom: 20px;">Precision Planning <br>via Local AI</h2>
                    <p>Our platform leverages the <strong>IBM Granite 3.3 2B</strong> model running locally through <strong>Ollama</strong>. This ensures that your sensitive project data never leaves your infrastructure while providing lightning-fast estimations for labor, materials, and timelines.</p>
                </div>
                <div class="glass-card">
                    <ul style="list-style: none;">
                        <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--accent-cyan);"></i> Fast, secure, offline processing</li>
                        <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--accent-cyan);"></i> Built-up area based cost analysis</li>
                        <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--accent-cyan);"></i> Detailed worker breakdown (Masons, Steel Workers)</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Real-World Scenarios -->
    <section id="scenarios">
        <div class="container">
            <h2 style="text-align: center; margin-bottom: 50px;">Real-World Scenarios</h2>
            
            <div class="scenario-card glass-card" onclick="toggleScenario(this)">
                <div class="scenario-header">
                    <h3>Residential G+2 (1000 sq yards)</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="scenario-body">
                    <div class="grid-2">
                        <div>
                            <h4>Worker Requirements</h4>
                            <p>Masons: 12 | Helpers: 25 | Steel Fixers: 8</p>
                        </div>
                        <div>
                            <h4>Timeline</h4>
                            <p>Total Duration: 180 Days (Approx.)</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="scenario-card glass-card" onclick="toggleScenario(this)">
                <div class="scenario-header">
                    <h3>1500 sq yard Project (90-day Timeline)</h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="scenario-body">
                    <p>Accelerated workforce requirement: 45 Workers daily. Material Buffer: 15% increase for rapid procurement.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Features -->
    <section id="features" style="padding: 100px 0; background: rgba(0,0,0,0.2);">
        <div class="container">
            <h2 style="text-align: center;">Core Features</h2>
            <div class="features-grid">
                <div class="feature-item glass-card">
                    <i class="fas fa-calculator"></i>
                    <h3>AI Cost Estimation</h3>
                </div>
                <div class="feature-item glass-card">
                    <i class="fas fa-users"></i>
                    <h3>Workforce Planning</h3>
                </div>
                <div class="feature-item glass-card">
                    <i class="fas fa-cubes"></i>
                    <h3>Material Planning</h3>
                </div>
                <div class="feature-item glass-card">
                    <i class="fas fa-drafting-compass"></i>
                    <h3>Blueprint Generation</h3>
                </div>
            </div>
        </div>
    </section>

    <!-- Tech Stack -->
    <section id="tech-stack" style="padding: 100px 0;">
        <div class="container" style="text-align: center;">
            <h2 style="margin-bottom: 40px;">Technology Stack</h2>
            <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 15px;">
                <span class="model-badge">Python 3.8+</span>
                <span class="model-badge">Flask</span>
                <span class="model-badge">IBM Granite 3.3 2B</span>
                <span class="model-badge">Ollama</span>
                <span class="model-badge">JavaScript</span>
                <span class="model-badge">Local Inference</span>
            </div>
        </div>
    </section>

    <!-- Demo Section -->
    <section id="demo" style="padding: 100px 0;">
        <div class="container">
            <div class="glass-card" style="max-width: 800px; margin: 0 auto;">
                <h2 style="margin-bottom: 25px; text-align: center;">Interactive Planning Demo</h2>
                <form id="demo-form">
                    <div class="grid-2">
                        <div style="display:flex; flex-direction:column;">
                            <label>Built-up Area (sq. ft.)</label>
                            <input type="number" id="area" placeholder="e.g. 5000" required>
                        </div>
                        <div style="display:flex; flex-direction:column;">
                            <label>Number of Floors</label>
                            <input type="number" id="floors" placeholder="e.g. 3" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Generate AI Analysis</button>
                </form>

                <div id="results" class="results-area glass-card" style="background: rgba(0,0,0,0.4); margin-top: 30px;">
                    <h3 style="color: var(--accent-cyan); margin-bottom: 15px;">AI-Generated Insights</h3>
                    <div id="results-content" class="grid-2">
                        <!-- JS injected here -->
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Requirements -->
    <section style="padding: 100px 0;">
        <div class="container">
            <div class="grid-2">
                <div class="glass-card">
                    <h3>Hardware Requirements</h3>
                    <ul style="margin-top: 15px;">
                        <li>CPU: Intel i5 / Ryzen 5</li>
                        <li>RAM: 8GB (16GB Rec.)</li>
                        <li>Storage: 10GB SSD</li>
                    </ul>
                </div>
                <div class="glass-card">
                    <h3>Software Requirements</h3>
                    <ul style="margin-top: 15px;">
                        <li>Python 3.8+</li>
                        <li>Ollama Desktop</li>
                        <li>Granite 3.3 2B Model</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Conclusion -->
    <footer style="padding: 100px 0; border-top: 1px solid var(--glass-border); text-align: center;">
        <div class="container">
            <h2>Fast. Accurate. Local.</h2>
            <p style="margin: 20px 0;">The future of construction management requires no cloud API keys.</p>
            <p>© 2024 AI-Construct Planning System | Engineering Excellence</p>
        </div>
    </footer>

    <script>
        // Scenario Toggle Logic
        function toggleScenario(element) {
            element.classList.toggle('active');
            const icon = element.querySelector('i');
            if(element.classList.contains('active')) {
                icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
            } else {
                icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
            }
        }

        // Demo Engine Simulation
        document.getElementById('demo-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const area = document.getElementById('area').value;
            const floors = document.getElementById('floors').value;
            const resultsDiv = document.getElementById('results');
            const content = document.getElementById('results-content');

            // Simulate AI Processing delay
            resultsDiv.style.display = 'block';
            content.innerHTML = '<p>Analysing parameters using Granite 3.3 2B...</p>';

            setTimeout(() => {
                // Construction Mathematics Simulation
                const totalCost = (area * 180).toLocaleString();
                const masons = Math.ceil(area / 400);
                const cement = Math.ceil(area * 0.45);
                const steel = (area * 3.5).toLocaleString();

                content.innerHTML = `
                    <div>
                        <p><strong>Workforce Breakdown</strong></p>
                        <ul>
                            <li>Masons: ${masons}</li>
                            <li>Helpers: ${masons * 2}</li>
                            <li>Engineers: ${floors}</li>
                        </ul>
                    </div>
                    <div>
                        <p><strong>Material Estimates</strong></p>
                        <ul>
                            <li>Cement: ${cement} Bags</li>
                            <li>Steel: ${steel} Kg</li>
                            <li>Bricks: ${(area * 12).toLocaleString()} Units</li>
                        </ul>
                    </div>
                    <div style="grid-column: 1 / -1; margin-top: 20px; border-top: 1px solid #333; padding-top: 15px;">
                        <p style="font-size: 1.2rem; color: var(--accent-cyan);">Estimated Project Budget: $${totalCost}</p>
                        <p><small>Note: This is an AI-generated mock based on local mathematics engine.</small></p>
                    </div>
                `;
            }, 1200);
        });
    </script>
</body>
</html>
